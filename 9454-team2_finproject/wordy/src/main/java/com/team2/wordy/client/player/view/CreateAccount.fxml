<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="CONTROLLER_NAME">
    <children>
        <Pane prefHeight="400.0" prefWidth="600.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- Centered the VBox and added spacing between elements -->
                <VBox alignment="CENTER_LEFT" layoutX="100.0" layoutY="20.0" prefWidth="400.0" spacing="12.0">
                    <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Create Your Account">
                            <font>
                                <Font name="Century Gothic Bold" size="20.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="10.0" />
                            </VBox.margin>
                        </Text>

                        <VBox spacing="5.0">
                            <children>
                                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Username">
                                    <font>
                                        <Font name="Century Gothic Bold" size="14.0" />
                                    </font>
                                </Text>
                                <TextField fx:id="userName" promptText="Choose a username" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Password">
                                    <font>
                                        <Font name="Century Gothic Bold" size="14.0" />
                                    </font>
                                </Text>
                                <PasswordField fx:id="Password" promptText="Enter password" />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Re-Type Password">
                                    <font>
                                        <Font name="Century Gothic Bold" size="14.0" />
                                    </font>
                                </Text>
                                <PasswordField fx:id="rePassword" promptText="Confirm password" />
                            </children>
                        </VBox>

                        <CheckBox fx:id="chkBox" mnemonicParsing="false" text="Show Password">
                            <font>
                                <Font name="Century Gothic" size="12.0" />
                            </font>
                        </CheckBox>

                        <!-- Buttons in an HBox for side-by-side layout -->
                        <HBox spacing="15.0">
                            <children>
                                <Button fx:id="createAccountButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="150.0" style="-fx-background-color: #2196F3;" text="Create Account" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="12.0" />
                                    </font>
                                </Button>
                                <Button fx:id="backButton" mnemonicParsing="false" prefHeight="30.0" prefWidth="80.0" text="Back" />
                            </children>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </HBox>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </children>
        </Pane>
    </children>
</AnchorPane>
