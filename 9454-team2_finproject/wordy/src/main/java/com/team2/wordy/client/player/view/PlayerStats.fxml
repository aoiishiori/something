<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.team2.wordy.client.player.controller.PlayerStats_Controller">
    <children>
        <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- Header area with Back button and Title -->
                <AnchorPane prefHeight="60.0">
                    <children>
                        <Button fx:id="backButton" layoutX="14.0" layoutY="15.0" mnemonicParsing="false" text="Back" AnchorPane.leftAnchor="15.0" AnchorPane.topAnchor="15.0" />
                        <Text layoutX="164.0" layoutY="41.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Wordy Achievements" textAlignment="CENTER" AnchorPane.leftAnchor="164.0" AnchorPane.rightAnchor="164.33740234375" AnchorPane.topAnchor="9.0">
                            <font>
                                <Font size="29.0" />
                            </font>
                        </Text>
                    </children>
                </AnchorPane>

                <!-- TabPane anchored to fill the remaining space -->
                <TabPane prefHeight="200.0" prefWidth="200.0" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                    <tabs>
                        <Tab fx:id="playerStats" text="My Stats">
                            <content>
                                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
                            </content></Tab>
                        <Tab fx:id="longestWord" text="Longest Word">
                            <content>
                                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
                            </content></Tab>
                        <Tab fx:id="roundWins" text="Round Wins">
                            <content>
                                <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" />
                            </content></Tab>
                    </tabs>
                </TabPane>
            </children>
        </VBox>
    </children>
</AnchorPane>
