<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.team2.wordy.client.player.controller.Login_Controller">
    <children>
        <Pane prefHeight="400.0" prefWidth="600.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
               
                <VBox alignment="CENTER_LEFT" layoutX="100.0" layoutY="50.0" prefHeight="300.0" prefWidth="400.0" spacing="10.0">
                    <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Username">
                            <font>
                                <Font name="Century Gothic Bold" size="15.0" />
                            </font>
                        </Text>
                        <TextField fx:id="userName" promptText="Enter Username">
                            <font>
                                <Font name="Century Gothic" size="14.0" />
                            </font>
                        </TextField>

                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Password">
                            <font>
                                <Font name="Century Gothic Bold" size="15.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </Text>
                        <PasswordField fx:id="Password" promptText="Enter Password">
                            <font>
                                <Font name="Century Gothic" size="14.0" />
                            </font>
                        </PasswordField>

                        <CheckBox fx:id="chkBox" mnemonicParsing="false" text="Show Password">
                            <font>
                                <Font name="Century Gothic" size="12.0" />
                            </font>
                        </CheckBox>

                        <Button fx:id="Login" alignment="CENTER" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Login">
                            <font>
                                <Font name="Century Gothic Bold" size="14.0" />
                            </font>
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </Button>

                        <Hyperlink fx:id="CreateAcc" alignment="CENTER" maxWidth="1.7976931348623157E308" text="Create an Account">
                            <font>
                                <Font name="Century Gothic" size="12.0" />
                            </font>
                        </Hyperlink>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                    </padding>
                </VBox>
            </children>
        </Pane>
    </children>
</AnchorPane>
