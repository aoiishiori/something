<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.team2.wordy.client.player.controller.LoadingScreen_Controller">
    <children>
        <!-- 1. Timer Area (Centered Top) -->
        <VBox alignment="TOP_CENTER" prefHeight="80.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="20.0">
            <children>
                <Label fx:id="timerLabel" text="00:00" textFill="#e41313">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="TIME REMAINING" />
            </children>
        </VBox>

        <!-- 2. Player Profile Left -->
        <HBox alignment="CENTER_LEFT" spacing="10.0" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <Circle fx:id="player1Avatar" fill="#ced4da" radius="25.0" stroke="BLACK" strokeType="INSIDE" />
                <VBox alignment="CENTER_LEFT">
                    <children>
                        <Label fx:id="player1Name" text="Waiting...">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                        <Label fx:id="player1Status" text="Disconnected" textFill="#7c7c7c" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- 3. Player Profile Right -->
        <HBox alignment="CENTER_RIGHT" spacing="10.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <VBox alignment="CENTER_RIGHT">
                    <children>
                        <Label fx:id="player2Name" text="Waiting...">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                        <Label fx:id="player2Status" text="Disconnected" textFill="#7c7c7c" />
                    </children>
                </VBox>
                <Circle fx:id="player2Avatar" fill="#ced4da" radius="25.0" stroke="BLACK" strokeType="INSIDE" />
            </children>
        </HBox>

        <!-- 4. Main Status (Centered) -->
        <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Text fx:id="statusText" strokeType="OUTSIDE" strokeWidth="0.0" text="Waiting for Players">
                            <font>
                                <Font size="30.0" />
                            </font>
                        </Text>
                        <Text fx:id="subStatusText" fill="#7c7c7c" strokeType="OUTSIDE" strokeWidth="0.0" text="Searching for match..." />
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</AnchorPane>